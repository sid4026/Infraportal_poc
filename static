    async function saveRule() {
        const name = document.getElementById('rb-name').value.trim();
        if (!name) { alert("Rule name is required."); return; }
        if (!CURRENT_TEMPLATE_ID) { alert("No template found for BIT project."); return; }

        // Phase 2: linked_rules uses flat if_column/if_value/operator/then_column/then_value
        // The rule builder allows multiple condition rows and action rows.
        // We save each IF+THEN pair as a separate linked_rule for simplicity.
        const condRows = Array.from(document.getElementById('rb-conditions').querySelectorAll('tr'));
        const actionEls = Array.from(document.querySelectorAll('[id^="rb-act-col-"]'));

        if (!condRows.length) { alert("Add at least one IF condition."); return; }
        if (!actionEls.length) { alert("Add at least one THEN action."); return; }

        // Collect valid conditions
        const conditions = [];
        condRows.forEach(row => {
            const idx = row.id.replace('rb-cond-','');
            const col = document.getElementById(`rb-cond-col-${idx}`)?.value;
            const op  = document.getElementById(`rb-cond-op-${idx}`)?.value || 'equals';
            const val = document.getElementById(`rb-cond-val-${idx}`)?.value?.trim();
            if (col && val) conditions.push({ col, op, val });
        });

        // Collect valid actions
        const actions = [];
        actionEls.forEach(sel => {
            const idx = sel.id.replace('rb-act-col-','');
            const col = sel.value;
            const valEl = document.getElementById(`rb-act-val-${idx}`);
            let val = valEl?.value?.trim() || '';
            if (val === '__custom__') val = document.getElementById(`rb-act-custom-${idx}`)?.value.trim() || '';
            if (col && val) actions.push({ col, val });
        });

        if (!conditions.length) { alert("Add at least one valid IF condition (column + value required)."); return; }
        if (!actions.length)    { alert("Add at least one valid THEN action (column + value required).");  return; }

        // Save each condition×action combination as a separate linked_rule row
        // (simplest mapping; one condition, one action per rule is most common)
        const token = localStorage.getItem('token');
        let saved = 0;
        for (const cond of conditions) {
            for (const act of actions) {
                const res = await fetch(API + `/api/superadmin/template/${CURRENT_TEMPLATE_ID}/linked_rules`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Auth-Token': token },
                    body: JSON.stringify({
                        rule_name: name,
                        if_column: cond.col,
                        if_value: cond.val,
                        operator: cond.op,
                        then_column: act.col,
                        then_value: act.val,
                        display_order: 0
                    })
                });
                const d = await res.json();
                if (d.ok) saved++;
                else { alert(d.error || 'Failed to save rule.'); }
            }
        }

        if (saved > 0) {
            await fetchLinkedRules();
            closeRuleBuilder();
            loadLinkedRulesList();
        }
    }

    // openModal — clean version, no manage-lookups-modal special case
    function openModal(id) {
        document.querySelectorAll(`#${id} input`).forEach(i => {
            if (i.type !== 'file' && i.type !== 'checkbox') i.value = '';
        });
        document.getElementById(id).classList.add('active');
    }

    // ── BURN-IN DATA ──────────────────────────────
    function debounceSearch() {
        clearTimeout(SEARCH_TIMER);
        SEARCH_TIMER = setTimeout(() => { CURRENT_PAGE = 1; loadBurnInData(); }, 350);
    }

    function changePerPage(val) { CURRENT_PER_PAGE = parseInt(val); CURRENT_PAGE = 1; loadBurnInData(); }

    async function loadBurnInData() {
        const search = document.getElementById('search-box')?.value || '';
        const token = localStorage.getItem("token");
        const headers = token ? { "X-Auth-Token": token } : {};
        const url = `${API}/api/fy/${CURRENT_FY}/data?page=${CURRENT_PAGE}&per_page=${CURRENT_PER_PAGE}&search=${encodeURIComponent(search)}`;
        const res = await fetch(url, { headers });
        const result = await res.json();
        BURN_IN_DATA = result.rows;
        TOTAL_ROWS = result.total;

        const isAdmin = document.body.classList.contains('is-admin') || document.body.classList.contains('is-superadmin');
        const canDelete = document.body.classList.contains('can-delete');

        document.getElementById('total-label').textContent = `${TOTAL_ROWS} total record${TOTAL_ROWS !== 1 ? 's' : ''}`;

        document.getElementById('burn-in-body').innerHTML = BURN_IN_DATA.map(r => `
            <tr id="row-${r.id}">
                ${canDelete ? `<td class="cb-col"><input type="checkbox" class="row-cb" value="${r.id}" onchange="onRowCheck(${r.id}, this.checked)"></td>` : ''}
                ${COLUMNS.map(c => `<td>${formatCell(c, r[c])}</td>`).join('')}
                ${isAdmin ? `<td style="text-align:center;">
                    <button class="btn btn-outline btn-icon" title="Edit" onclick="openEditor(${r.id})">${SVG_PENCIL}</button>
                    <button class="btn btn-outline btn-icon btn-danger del-only" title="Delete" onclick="deleteRow(${r.id})">${SVG_TRASH}</button>
                </td>` : ''}
            </tr>`).join('');

        renderPagination();
        clearSelection();
    }

    function renderPagination() {
        const totalPages = Math.ceil(TOTAL_ROWS / CURRENT_PER_PAGE);
        if (totalPages <= 1) { document.getElementById('pagination').innerHTML = ''; return; }
        let html = '';
        const start = Math.max(1, CURRENT_PAGE - 2);
        const end = Math.min(totalPages, CURRENT_PAGE + 2);
        if (start > 1) html += `<button class="page-btn" onclick="goPage(1)">1</button>${start > 2 ? '<span style="padding:0 4px">…</span>' : ''}`;
        for (let i = start; i <= end; i++) {
            html += `<button class="page-btn ${i === CURRENT_PAGE ? 'active' : ''}" onclick="goPage(${i})">${i}</button>`;
        }
        if (end < totalPages) html += `${end < totalPages - 1 ? '<span style="padding:0 4px">…</span>' : ''}<button class="page-btn" onclick="goPage(${totalPages})">${totalPages}</button>`;
        document.getElementById('pagination').innerHTML = html;
    }

    function goPage(p) { CURRENT_PAGE = p; loadBurnInData(); }

    // ── SELECTION & BULK DELETE ────────────────────
    function onRowCheck(id, checked) {
        if (checked) SELECTED_IDS.add(id); else SELECTED_IDS.delete(id);
        updateBulkBar();
    }

    function toggleSelectAll(checked) {
        BURN_IN_DATA.forEach(r => {
            if (checked) SELECTED_IDS.add(r.id); else SELECTED_IDS.delete(r.id);
        });
        document.querySelectorAll('.row-cb').forEach(cb => cb.checked = checked);
        updateBulkBar();
    }

    function updateBulkBar() {
        const bar = document.getElementById('bulk-bar');
        const n = SELECTED_IDS.size;
        bar.classList.toggle('visible', n > 0);
        document.getElementById('bulk-count').textContent = `${n} row${n !== 1 ? 's' : ''} selected`;
    }

    function clearSelection() {
        SELECTED_IDS.clear();
        document.querySelectorAll('.row-cb').forEach(cb => cb.checked = false);
        const cb = document.getElementById('select-all-cb');
        if (cb) cb.checked = false;
        updateBulkBar();
    }

    async function bulkDelete() {
        if (!confirm(`Permanently delete ${SELECTED_IDS.size} record(s)?`)) return;
        await fetch(API + `/api/admin/fy/${CURRENT_FY}/rows/bulk`, {
            method: "DELETE", headers: { "Content-Type": "application/json", "X-Auth-Token": localStorage.getItem("token") },
            body: JSON.stringify({ ids: [...SELECTED_IDS] })
        });
        loadBurnInData();
    }

    // ── CELL FORMATTING ───────────────────────────
    function formatCell(col, val) {
        if (val === null || val === undefined || val === '') return '';
        const cls = getCellClass(col, val);
        if (cls) return `<span class="${cls}">${val}</span>`;
        return val;
    }

    // ── INLINE EDITOR ─────────────────────────────
    function buildInput(col, val = '') {
        if (FORMULA_COLS.has(col)) return `<input type="text" class="inline-input formula-cell" id="i-${col}" value="${val}" readonly>`;
        if (col === 'Date Performed') return `<input type="date" class="inline-input" id="i-${col}" value="${val ? val.split('T')[0].split(' ')[0] : ''}" onchange="calcFormulas(); evaluateRules();">`;
        if (col === 'OS Version') {
            const names = [...new Set(OS_BUILDS.map(o => o.os_name))];
            const opts = names.map(n => `<option value="${n}" ${val===n?'selected':''}>${n}</option>`).join('');
            return `<select class="inline-input" id="i-${col}" onchange="onOsVersionChange(this.value); evaluateRules();">${opts ? '<option value="">Select...</option>' + opts : '<option value="">No OS defined</option>'}</select>`;
        }
        if (col === 'OS Release') {
            const curOs = document.getElementById('i-OS Version')?.value || '';
            const releases = getOsReleases(curOs);
            const opts = releases.map(r => `<option value="${r}" ${val===r?'selected':''}>${r}</option>`).join('');
            return `<select class="inline-input" id="i-${col}" onchange="calcFormulas(); evaluateRules();"><option value="">Select...</option>${opts}</select>`;
        }
        if (SYSTEM_LOOKUPS[col]) {
            const opts = SYSTEM_LOOKUPS[col].map(o => `<option value="${o.lookup_key}" ${val===o.lookup_key?'selected':''}>${o.lookup_key}</option>`).join('');
            // formula-triggering cols keep calcFormulas; ALL selects also trigger evaluateRules
            const formulaCols = ['CPU Test','RAM Test','Storage Test','Video Test','2D Graphics','3D Graphics','Is Retest'];
            const oc = formulaCols.includes(col)
                ? 'onchange="calcFormulas(); evaluateRules();"'
                : 'onchange="evaluateRules();"';
            return `<select class="inline-input" id="i-${col}" ${oc}><option value="">Select...</option>${opts}</select>`;
        }
        const dis = ['CPU Load %','RAM Load %','Storage Load %','GPU Load %','CPU Max °C','RAM Max °C','SSD Max °C','GPU Max °C','Retest Attempt'].includes(col) && val === 'NA' ? 'readonly class="inline-input disabled-cell"' : '';
        return `<input type="text" class="inline-input" id="i-${col}" value="${val}" ${dis} onchange="evaluateRules();">`;
    }

    function onOsVersionChange(osName) {
        const releases = getOsReleases(osName);
        const sel = document.getElementById('i-OS Release');
        if (sel) {
            sel.innerHTML = '<option value="">Select...</option>' + releases.map(r => `<option value="${r}">${r}</option>`).join('');
            // Auto-select first release if only one option exists
            if (releases.length === 1) sel.value = releases[0];
        }
        calcFormulas(); // Now safe — OS Release select is already repopulated above
    }

    function openEditor(id = null) {
        const tr = document.createElement('tr');
        let data = {};
        if (id) { data = BURN_IN_DATA.find(r => r.id === id); tr.id = `row-${id}`; }
        const canDelete = document.body.classList.contains('can-delete');
        tr.id = id ? `row-${id}` : 'row-new';
        tr.innerHTML =
            (canDelete ? '<td class="cb-col"></td>' : '') +
            COLUMNS.map(c => `<td>${buildInput(c, data[c] || '')}</td>`).join('') +
            `<td style="text-align:center;display:flex;gap:4px;justify-content:center;padding:7px 6px;">
                <button class="btn btn-coral btn-icon" title="Save" onclick="saveInlineRow(${id || 'null'})">${SVG_FLOPPY}</button>
                <button class="btn btn-outline btn-icon" title="Cancel" onclick="cancelEditor(${id || 'null'})">${SVG_CANCEL}</button>
             </td>`;
        if (id) document.getElementById(`row-${id}`).replaceWith(tr);
        else document.getElementById('burn-in-body').insertBefore(tr, document.getElementById('burn-in-body').firstChild);
    }

    function cancelEditor(id = null) {
        if (id) {
            // Restore original read-only row
            loadBurnInData();
        } else {
            const newRow = document.getElementById('row-new');
            if (newRow) newRow.remove();
        }
    }

    function calcFormulas() {
        // OS Build ID — resolve from os_builds
        const osV = document.getElementById('i-OS Version')?.value;
        const osR = document.getElementById('i-OS Release')?.value;
        if (osV && osR) {
            document.getElementById('i-OS Build ID').value = getOsBuildId(osV, osR);
        }

        // Test Combination
        const comboMap = { 'CPU Test':'CPU', 'RAM Test':'RAM', 'Storage Test':'Storage', 'Video Test':'Video', '2D Graphics':'2D', '3D Graphics':'3D' };
        let combo = '';
        Object.keys(comboMap).forEach(k => { if (document.getElementById(`i-${k}`)?.value === 'Yes') combo += comboMap[k] + ' '; });
        document.getElementById('i-Test Combination').value = combo.trim();

        // NA toggles for Load/Temp
        [{ t:'CPU Test', l:'CPU Load %', c:'CPU Max °C' }, { t:'RAM Test', l:'RAM Load %', c:'RAM Max °C' }, { t:'Storage Test', l:'Storage Load %', c:'SSD Max °C' }, { t:'Video Test', l:'GPU Load %', c:'GPU Max °C' }].forEach(m => {
            const isNo = document.getElementById(`i-${m.t}`)?.value === 'No';
            [m.l, m.c].forEach(f => {
                const el = document.getElementById(`i-${f}`); if (!el) return;
                if (isNo) { el.value = 'NA'; el.classList.add('disabled-cell'); el.readOnly = true; }
                else { el.classList.remove('disabled-cell'); el.readOnly = false; if (el.value === 'NA') el.value = ''; }
            });
        });

        // Retest NA toggle
        const isRetestNo = document.getElementById('i-Is Retest')?.value === 'No';
        ['Retest Attempt', 'Retest Reason'].forEach(f => {
            const el = document.getElementById(`i-${f}`); if (!el) return;
            if (isRetestNo) { el.value = 'NA'; el.classList.add('disabled-cell'); el.readOnly = true; }
            else { el.classList.remove('disabled-cell'); el.readOnly = false; if (el.value === 'NA') el.value = ''; }
        });
    }

    async function saveInlineRow(id = null) {
        const payload = {};
        COLUMNS.forEach(c => { payload[c] = document.getElementById(`i-${c}`)?.value || ''; });
        if (!payload['Date Performed'] || !payload['Technician']) { alert("Date and Technician are required."); return; }
        const method = id ? "PUT" : "POST";
        const endpoint = id ? `/api/admin/fy/${CURRENT_FY}/rows/${id}` : `/api/admin/fy/${CURRENT_FY}/rows`;
        await fetch(API + endpoint, {
            method, headers: { "Content-Type": "application/json", "X-Auth-Token": localStorage.getItem("token") },
            body: JSON.stringify(payload)
        });
        loadBurnInData();
    }

    async function deleteRow(id) {
        if (!confirm("Permanently delete this record?")) return;
        await fetch(API + `/api/admin/fy/${CURRENT_FY}/rows/${id}`, { method: "DELETE", headers: { "X-Auth-Token": localStorage.getItem("token") } });
        loadBurnInData();
    }

    // ── UPLOAD WITH CONFLICT DETECTION ────────────
    async function uploadXlsx(input) {
        if (!input.files[0]) return;
        const fd = new FormData(); fd.append("file", input.files[0]);
        const res = await fetch(API + `/api/admin/fy/${CURRENT_FY}/upload`, {
            method: "POST", headers: { "X-Auth-Token": localStorage.getItem("token") }, body: fd
        });
        const data = await res.json();
        input.value = ''; // Reset file input
        if (!data.ok) { alert("Upload error: " + data.error); return; }

        if (data.conflicts && data.conflicts.length > 0) {
            PENDING_CONFLICTS = data.conflicts;
            showConflictModal(data.inserted, data.conflicts);
        } else {
            alert(`Upload complete. ${data.inserted} row(s) inserted.`);
            loadBurnInData();
        }
    }

    function showConflictModal(inserted, conflicts) {
        document.getElementById('conflict-summary').textContent =
            `✅ ${inserted} new row(s) inserted. ⚠️ ${conflicts.length} conflict(s) detected — these already exist by Serial Number + Date. Select which to insert anyway:`;
        document.getElementById('conflict-list').innerHTML = conflicts.map((c, i) =>
            `<div class="conflict-row">
                <input type="checkbox" class="conflict-cb" data-idx="${i}">
                <div>
                    <strong>${c.serial || '(no serial)'}</strong> — ${c.date}
                    <span class="conflict-badge">${c.manufacturer} ${c.model}</span>
                    <span style="color:var(--muted);font-size:11px;"> by ${c.technician}</span>
                </div>
             </div>`
        ).join('');
        openModal('conflict-modal');
    }

    function selectAllConflicts(checked) {
        document.querySelectorAll('.conflict-cb').forEach(cb => cb.checked = checked);
    }

    async function forceInsertSelected() {
        const selected = [];
        document.querySelectorAll('.conflict-cb:checked').forEach(cb => {
            selected.push(PENDING_CONFLICTS[parseInt(cb.getAttribute('data-idx'))].row_data);
        });
        if (selected.length === 0) { alert("No conflicts selected."); return; }
        const res = await fetch(API + `/api/admin/fy/${CURRENT_FY}/upload/force`, {
            method: "POST", headers: { "Content-Type": "application/json", "X-Auth-Token": localStorage.getItem("token") },
            body: JSON.stringify({ rows: selected })
        });
        const data = await res.json();
        closeModals();
        alert(`${data.inserted} additional row(s) inserted.`);
        loadBurnInData();
    }

    // ── EXPORTS ───────────────────────────────────
    function downloadXlsx() {
        const token = localStorage.getItem("token");
        window.location = `${API}/api/fy/${CURRENT_FY}/download/xlsx?token=${token}`;
    }
    function downloadPdf() {
        window.location = `${API}/api/fy/${CURRENT_FY}/download/pdf`;
    }

    // ── USER MANAGEMENT ───────────────────────────
    function openUserModal(id = null) {
        document.getElementById('u-id').value = id || '';
        document.getElementById('u-modal-title').innerText = id ? "Edit User" : "Create User";
        document.getElementById('u-pass-group').style.display = id ? "none" : "block";
        document.getElementById('u-name').disabled = !!id;
        if (id) {
            const u = USER_LIST_CACHE.find(x => x.id === id);
            document.getElementById('u-name').value = u.username;
            document.getElementById('u-first').value = u.first_name || '';
            document.getElementById('u-last').value = u.last_name || '';
            document.getElementById('u-email').value = u.email || '';
            document.getElementById('u-phone').value = u.phone || '';
            document.getElementById('u-role').value = u.role;
            document.getElementById('u-can-delete').checked = !!u.can_delete;
        } else {
            document.querySelectorAll('#add-user-modal input').forEach(i => { if (i.type !== 'checkbox') i.value = ''; });
            document.getElementById('u-can-delete').checked = false;
        }
        openModal('add-user-modal');
    }

    async function loadUsers() {
        const res = await fetch(API + "/api/superadmin/users", { headers: { "X-Auth-Token": localStorage.getItem("token") } });
        USER_LIST_CACHE = await res.json();
        document.getElementById('user-list').innerHTML = USER_LIST_CACHE.map(u => `<tr>
            <td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${u.is_active ? '#16a34a' : '#9ca3af'};margin-right:5px;"></span>${u.is_active ? 'Online' : 'Offline'}</td>
            <td>${u.username}</td><td>${u.first_name} ${u.last_name}</td><td>${u.email || '—'}</td><td>${u.phone || '—'}</td>
            <td><span style="background:#eee;padding:2px 8px;border-radius:4px;text-transform:capitalize;">${u.role}</span></td>
            <td>${u.can_delete ? 'Yes' : 'No'}</td>
            <td style="text-align:center;">
                <button class="btn btn-outline btn-icon" title="Edit" onclick="openUserModal(${u.id})">${SVG_PENCIL}</button>
                ${u.is_active && u.id !== MY_PROFILE.id ? `<button class="btn btn-outline btn-icon btn-danger" title="Force Logout" onclick="killSession('${u.username}')">${SVG_POWER}</button>` : ''}
                ${u.id === MY_PROFILE.id ? '<span style="color:var(--muted);font-size:12px;margin-left:5px;">(You)</span>' : `<button class="btn btn-outline btn-icon btn-danger" title="Delete" onclick="deleteUser(${u.id})">${SVG_TRASH}</button>`}
            </td></tr>`).join('');
    }

    async function saveUser() {
        const id = document.getElementById('u-id').value;
        const payload = { username: document.getElementById('u-name').value, role: document.getElementById('u-role').value, first_name: document.getElementById('u-first').value, last_name: document.getElementById('u-last').value, email: document.getElementById('u-email').value, phone: document.getElementById('u-phone').value, can_delete: document.getElementById('u-can-delete').checked };
        if (!id) payload.password = document.getElementById('u-pass').value;
        const res = await fetch(API + (id ? `/api/superadmin/users/${id}` : `/api/superadmin/users`), {
            method: id ? "PUT" : "POST", headers: { "Content-Type": "application/json", "X-Auth-Token": localStorage.getItem("token") },
            body: JSON.stringify(payload)
        });
        const data = await res.json(); if (data.error) alert(data.error); else { closeModals(); loadUsers(); }
    }

    async function killSession(user) {
        if (!confirm("Force logout this user globally?")) return;
        await fetch(API + `/api/superadmin/users/${user}/kill`, { method: "POST", headers: { "X-Auth-Token": localStorage.getItem("token") } });
        loadUsers();
    }
    async function deleteUser(id) {
        if (!confirm("Delete user?")) return;
        const res = await fetch(API + `/api/superadmin/users/${id}`, { method: "DELETE", headers: { "X-Auth-Token": localStorage.getItem("token") } });
        const data = await res.json(); if (data.error) alert(data.error); loadUsers();
    }

    // ── LOGS ──────────────────────────────────────
    async function loadLogs() {
        const res = await fetch(API + "/api/superadmin/logs", { headers: { "X-Auth-Token": localStorage.getItem("token") } });
        document.getElementById('logs-list').innerHTML = (await res.json()).map(l =>
            `<tr><td style="color:var(--muted)">${new Date(l.timestamp).toLocaleString()}</td><td style="font-weight:600;">${l.username}</td><td>${l.action}</td></tr>`
        ).join('');
    }
    async function purgeLogs(days) {
        if (!confirm(`Delete all logs older than ${days} days?`)) return;
        await fetch(API + `/api/superadmin/logs/purge/${days}`, { method: "DELETE", headers: { "X-Auth-Token": localStorage.getItem("token") } });
        loadLogs();
    }

    // ── VAULT ─────────────────────────────────────
    async function loadVault() {
        const res = await fetch(API + "/api/vault", { headers: { "X-Auth-Token": localStorage.getItem("token") } });
        document.getElementById('vault-list').innerHTML = (await res.json()).map(c =>
            `<div class="card"><h4 style="color:var(--coral);">${c.app_name}</h4><p style="font-size:13px;color:var(--muted);">${c.portal_url}</p><p style="font-size:13px;margin:10px 0;">User: ${c.username}</p><button class="btn btn-outline btn-sm" onclick="navigator.clipboard.writeText('${c.password}'); alert('Copied!')">Copy Password</button></div>`
        ).join('');
    }
    async function saveVault() {
        await fetch(API + "/api/vault", {
            method: "POST", headers: { "Content-Type": "application/json", "X-Auth-Token": localStorage.getItem("token") },
            body: JSON.stringify({ app_name: document.getElementById('v-app').value, portal_url: document.getElementById('v-url').value, username: document.getElementById('v-user').value, password: document.getElementById('v-pass').value })
        });
        closeModals(); loadVault();
    }

    init();
</script>
