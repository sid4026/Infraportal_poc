    function removeRbCondition(rowId) {
        const tbody = document.getElementById('rb-conditions');
        if (tbody.rows.length <= 1) return; // keep at least one row
        document.getElementById(rowId).remove();
        // If only one row left, reset its And/Or cell to dash
        if (tbody.rows.length === 1) {
            const firstRow = tbody.rows[0];
            const andorCell = firstRow.cells[1];
            andorCell.innerHTML = '<span style="font-size:12px;color:var(--muted);font-style:italic;">—</span>';
        }
