<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ACGI-IT-Infra</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #F9F1EA; --surface: #FFFFFF; --text: #1A1A1A; --muted: #6B7280; --coral: #F29C8D; --coral-hover: #E08575; --border: rgba(0,0,0,0.08); }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
        body { background: var(--bg); color: var(--text); }
        nav { display: flex; justify-content: space-between; padding: 15px 40px; align-items: center; background: var(--surface); border-bottom: 1px solid var(--border); }
        .logo { font-size: 22px; font-weight: 700; color: var(--coral); cursor: pointer; }
        .nav-links { display: flex; gap: 30px; align-items: center; }
        .nav-item { font-weight: 500; cursor: pointer; position: relative; color: var(--text); transition: color 0.2s; }
        .nav-item:hover { color: var(--coral); }
        .nav-item.active { color: var(--coral); font-weight: 700; }
        .dropdown { position: relative; }
        .dropdown-menu { display: none; position: absolute; top: 100%; right: 0; background: var(--surface); box-shadow: 0 10px 25px rgba(0,0,0,0.05); padding: 10px; border-radius: 8px; border: 1px solid var(--border); min-width: 200px; z-index: 100; }
        .dropdown:hover .dropdown-menu { display: block; }
        .dropdown-item { display: flex; align-items: center; gap: 8px; padding: 8px 12px; color: var(--muted); cursor: pointer; border-radius: 4px; margin-bottom: 2px; }
        .dropdown-item:hover { background: var(--bg); color: var(--coral); }
        .btn { padding: 8px 16px; border-radius: 99px; border: none; font-weight: 500; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; font-size: 13px; }
        .btn-sm { padding: 4px 10px; font-size: 12px; }
        .btn-icon { width: 28px; height: 28px; padding: 0; border-radius: 6px; }
        .btn-coral { background: var(--coral); color: white; }
        .btn-coral:hover { background: var(--coral-hover); }
        .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text); }
        .btn-outline:hover { border-color: var(--coral); color: var(--coral); }
        .btn-danger { background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5; }

        /* Add button with hover submenu */
        .add-btn-wrap { position: relative; }
        .add-btn-wrap .add-submenu { display: none; position: absolute; top: calc(100% + 6px); right: 0; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.08); min-width: 170px; z-index: 200; padding: 6px; }
        .add-btn-wrap:hover .add-submenu { display: block; }
        .add-submenu-item { padding: 8px 12px; border-radius: 6px; cursor: pointer; font-size: 13px; color: var(--text); display: flex; align-items: center; gap: 8px; }
        .add-submenu-item:hover { background: var(--bg); color: var(--coral); }

        .page { display: none; padding: 40px; max-width: 98%; margin: 0 auto; }
        .page.active { display: block; }
        .card { background: var(--surface); padding: 24px; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 20px; }
        .auth-only, .super-only, .admin-only, .del-only { display: none !important; }
        .admin-action-bar { display: none !important; }
        body.is-auth .auth-only { display: block !important; }
        body.is-auth .public-only { display: none !important; }
        body.is-superadmin .super-only { display: block !important; }
        body.is-admin .admin-action-bar, body.is-superadmin .admin-action-bar { display: flex !important; gap: 10px; }
        body.is-admin .admin-only, body.is-superadmin .admin-only { display: block !important; }
        body.can-delete .del-only { display: inline-flex !important; }

        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; }
        .modal-overlay.active { display: flex; }
        .modal { background: var(--surface); padding: 30px; border-radius: 12px; width: 500px; max-width: 95%; display: flex; flex-direction: column; max-height: 90vh; overflow-y: auto; }
        .modal-lg { width: 720px; }
        .input-group { margin-bottom: 15px; }
        .input-group label { display: block; margin-bottom: 5px; font-size: 13px; font-weight: 500; color: var(--muted); }
        .input-group input, .input-group select, .input-group textarea { width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 6px; font-family: inherit; font-size: 14px; }
        .hint { font-size: 11px; color: var(--muted); margin-top: 4px; }

        /* Table */
        .table-container { overflow-x: auto; overflow-y: auto; max-height: 65vh; position: relative; }
        table { width: max-content; text-align: left; border-collapse: separate; border-spacing: 0; font-size: 13px; }
        thead { position: sticky; top: 0; z-index: 20; }
        th { padding: 10px 12px; border-bottom: 2px solid var(--border); background: #F3F4F6; white-space: nowrap; }
        td { padding: 7px 12px; border-bottom: 1px solid var(--border); white-space: nowrap; }
        .inline-input { padding: 5px 8px; border: 1px solid var(--coral); border-radius: 4px; width: 110px; font-family: inherit; font-size: 12px; }
        select.inline-input { width: 120px; }
        .inline-input.formula-cell { background: #f3f4f6; border-color: var(--border); color: var(--muted); cursor: not-allowed; }
        .inline-input.disabled-cell { background: #e5e7eb; color: #9ca3af; }

        /* Checkbox column */
        .cb-col { width: 36px; text-align: center; }
        input[type=checkbox] { cursor: pointer; width: 15px; height: 15px; }

        /* Pagination & search bar */
        .table-controls { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
        .search-box { padding: 8px 14px; border: 1px solid var(--border); border-radius: 99px; font-size: 13px; width: 240px; outline: none; }
        .search-box:focus { border-color: var(--coral); }
        .per-page-select { padding: 6px 10px; border: 1px solid var(--border); border-radius: 6px; font-size: 13px; }
        .pagination { display: flex; gap: 4px; align-items: center; margin-top: 12px; }
        .page-btn { padding: 5px 11px; border-radius: 6px; border: 1px solid var(--border); cursor: pointer; font-size: 13px; background: var(--surface); }
        .page-btn.active { background: var(--coral); color: white; border-color: var(--coral); }
        .page-btn:hover:not(.active) { border-color: var(--coral); color: var(--coral); }

        /* FY title with edit */
        .fy-title-wrap { display: flex; align-items: center; gap: 8px; }
        .fy-title-text { font-size: 20px; font-weight: 700; }
        .fy-edit-btn { background: none; border: none; cursor: pointer; color: var(--muted); padding: 2px; border-radius: 4px; display: flex; align-items: center; }
        .fy-edit-btn:hover { color: var(--coral); }

        /* FY selector tabs */
        .fy-tabs { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
        .fy-tab { padding: 5px 14px; border-radius: 99px; border: 1px solid var(--border); cursor: pointer; font-size: 13px; font-weight: 500; }
        .fy-tab.active { background: var(--coral); color: white; border-color: var(--coral); }
        .fy-tab:hover:not(.active) { border-color: var(--coral); color: var(--coral); }

        /* Conflict modal */
        .conflict-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
        .conflict-row:last-child { border-bottom: none; }
        .conflict-badge { font-size: 11px; background: #fef3c7; color: #92400e; padding: 2px 8px; border-radius: 99px; }

        /* Status badges */
        .avatar-circle { width: 32px; height: 32px; border-radius: 50%; background: var(--coral); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; overflow: hidden; }
        .avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
        /* Phase 2 — display rule CSS classes (DB-driven, replaces hardcoded status classes) */
        .highlight-green  { color: #16a34a; font-weight: 600; background: #dcfce7; padding: 2px 8px; border-radius: 4px; display:inline-block; }
        .highlight-red    { color: #dc2626; font-weight: 600; background: #fee2e2; padding: 2px 8px; border-radius: 4px; display:inline-block; }
        .highlight-amber  { color: #d97706; font-weight: 600; background: #fef3c7; padding: 2px 8px; border-radius: 4px; display:inline-block; }
        .highlight-grey   { color: #9ca3af; background: #f3f4f6; padding: 2px 8px; border-radius: 4px; display:inline-block; }
        .font-italic { font-style: italic; }
        .font-bold   { font-weight: 700; }
        .font-normal { font-style: normal; font-weight: 400; }
        .icon-svg { width: 16px; height: 16px; stroke-width: 2; stroke: currentColor; fill: none; stroke-linecap: round; stroke-linejoin: round; }

        /* OS Builds table */
        .os-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .os-table th, .os-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); text-align: left; }
        .os-table th { background: #f3f4f6; font-weight: 600; }

        /* Bulk delete bar */
        .bulk-bar { display: none; align-items: center; gap: 10px; padding: 8px 14px; background: #fef3c7; border-radius: 8px; font-size: 13px; margin-bottom: 10px; }
        .bulk-bar.visible { display: flex; }
    </style>
</head>
<body>
<nav>
    <div class="logo" onclick="nav('home')">ACGI-IT-Infra</div>
    <div class="nav-links">
        <div class="nav-item nav-tgt" id="nav-home" onclick="nav('home')">Home</div>
        <div class="dropdown">
            <div class="nav-item nav-tgt" id="nav-services">Services ▼</div>
            <div class="dropdown-menu">
                <div class="dropdown-item" onclick="nav('burnin')">Burn-In Report</div>
                <div class="dropdown-item" onclick="secureNav('fff')">Server Inventory (FFF)</div>
                <div class="dropdown-item" onclick="secureNav('fff')">SSL Expiry (FFF)</div>
                <div class="dropdown-item" onclick="secureNav('fff')">Server Licenses (FFF)</div>
                <div class="dropdown-item" onclick="secureNav('fff')">Infra SOP (FFF)</div>
            </div>
        </div>
        <div class="nav-item nav-tgt" id="nav-achievements" onclick="nav('achievements')">Achievements</div>
        <div class="nav-item nav-tgt" id="nav-about" onclick="nav('about')">About</div>
        <div class="nav-item nav-tgt" id="nav-contact" onclick="nav('contact')">Contact</div>
        <div class="dropdown super-only">
            <div class="nav-item nav-tgt" id="nav-admin">Admin Control ▼</div>
            <div class="dropdown-menu">
                <div class="dropdown-item" onclick="nav('users')">User Management</div>
                <div class="dropdown-item" onclick="nav('logs')">Activity Logs</div>
                <div class="dropdown-item" onclick="nav('os-builds')">OS Version Manager</div>
            </div>
        </div>
        <button class="btn btn-outline public-only" onclick="openModal('login-modal')">Login</button>
        <div class="dropdown auth-only">
            <div style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                <div class="avatar-circle" id="nav-avatar">U</div>
                <span id="nav-username" style="font-weight:500;text-transform:capitalize;">Profile</span>
            </div>
            <div class="dropdown-menu">
                <div class="dropdown-item" onclick="openProfile()">My Profile</div>

                <div class="dropdown-item" onclick="nav('vault')">Credential Vault</div>
                <div class="dropdown-item" onclick="logout()">Logout</div>
            </div>
        </div>
    </div>
</nav>

<!-- PAGES -->
<div id="page-home" class="page active"><h1>ACGI-IT-Infra Portal</h1><p class="hint" style="margin-top:8px;">Hardware analytics and infrastructure management.</p></div>
<div id="page-about" class="page"><h1>About ACGI-IT-Infra</h1><p class="hint" style="margin-top:8px;">IT Infrastructure Operations and Validation details.</p></div>
<div id="page-contact" class="page"><h1>Contact Support</h1><p class="hint" style="margin-top:8px;">Reach out to the IT infra team.</p></div>
<div id="page-achievements" class="page"><h1>IT Achievements (FFFM)</h1><p class="hint" style="margin-top:8px;">Public showcase coming soon.</p></div>
<div id="page-fff" class="page"><h1>Confidential Module (FFF)</h1><p class="hint" style="margin-top:8px;">Access restricted. Please log in.</p></div>

<!-- USER MANAGEMENT -->
<div id="page-users" class="page">
    <div style="display:flex;justify-content:space-between;margin-bottom:20px;">
        <h2>RBAC User Management</h2>
        <button class="btn btn-coral" onclick="openUserModal()"><svg class="icon-svg" viewBox="0 0 24 24"><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0M6 21v-2a4 4 0 0 1 4-4h4c.348 0 .686.045 1.008.128M16 19h6M19 16v6"/></svg> Create User</button>
    </div>
    <div class="card table-container">
        <table style="width:100%">
            <tr><th>Status</th><th>Username</th><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Can Delete</th><th>Actions</th></tr>
            <tbody id="user-list"></tbody>
        </table>
    </div>
</div>

<!-- ACTIVITY LOGS -->
<div id="page-logs" class="page">
    <div style="display:flex;justify-content:space-between;margin-bottom:20px;">
        <h2>System Activity Logs</h2>
        <div style="display:flex;gap:10px;">
            <button class="btn btn-outline btn-danger btn-sm" onclick="purgeLogs(7)">Purge &gt; 7 Days</button>
            <button class="btn btn-outline btn-danger btn-sm" onclick="purgeLogs(30)">Purge &gt; 30 Days</button>
        </div>
    </div>
    <div class="card table-container" style="max-height:60vh;">
        <table style="width:100%">
            <tr><th style="width:200px">Timestamp</th><th style="width:150px">User</th><th>Action</th></tr>
            <tbody id="logs-list"></tbody>
        </table>
    </div>
</div>

<!-- VAULT -->
<div id="page-vault" class="page">
    <div style="display:flex;justify-content:space-between;margin-bottom:20px;">
        <h2>My Credential Vault</h2>
        <button class="btn btn-coral" onclick="openModal('add-vault-modal')"><svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 5l0 14M5 12l14 0"/></svg> Add Credential</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;" id="vault-list"></div>
</div>

<!-- OS BUILDS MANAGER (SuperAdmin) -->
<div id="page-os-builds" class="page">
    <div style="display:flex;justify-content:space-between;margin-bottom:20px;">
        <div>
            <h2>OS Version Manager</h2>
            <p class="hint" style="margin-top:4px;">Define all valid OS Name + Release + Build ID combinations. These drive all OS dropdowns portal-wide.</p>
        </div>
        <button class="btn btn-coral" onclick="openModal('add-os-modal')"><svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 5l0 14M5 12l14 0"/></svg> Add OS Build</button>
    </div>
    <div class="card">
        <table class="os-table">
            <thead><tr><th>OS Name</th><th>OS Release</th><th>Build ID</th><th style="width:60px">Delete</th></tr></thead>
            <tbody id="os-builds-list"></tbody>
        </table>
    </div>
</div>

<!-- BURN-IN PAGE -->
<div id="page-burnin" class="page">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;flex-wrap:wrap;gap:10px;">
        <div>
            <div class="fy-title-wrap">
                <span class="fy-title-text" id="fy-title-text">Client Machine Analytics</span>
                <button class="fy-edit-btn admin-only" title="Rename this FY" onclick="openFyRenameModal()">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/><path d="M13.5 6.5l4 4"/></svg>
                </button>
            </div>
            <div class="fy-tabs" id="fy-tabs" style="margin-top:10px;"></div>
        </div>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <!-- Public: PDF only -->
            <button class="btn btn-outline public-only" onclick="downloadPdf()">
                <svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2M7 11l5 5l5-5M12 4l0 12"/></svg> Export PDF
            </button>
            <!-- Admin/SuperAdmin: both options -->
            <div class="dropdown admin-only">
                <button class="btn btn-outline">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2M7 11l5 5l5-5M12 4l0 12"/></svg> Export ▼
                </button>
                <div class="dropdown-menu" style="min-width:140px;">
                    <div class="dropdown-item" onclick="downloadXlsx()">Export XLSX</div>
                    <div class="dropdown-item" onclick="downloadPdf()">Export PDF</div>
                </div>
            </div>
            <div class="admin-action-bar">
                <input type="file" id="upload-file" style="display:none;" accept=".xlsx" onchange="uploadXlsx(this)">
                <button class="btn btn-outline" onclick="document.getElementById('upload-file').click()">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2M7 9l5-5l5 5M12 4l0 12"/></svg> Upload
                </button>
                <!-- Add button with submenu -->
                <div class="add-btn-wrap">
                    <button class="btn btn-coral">
                        <svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 5l0 14M5 12l14 0"/></svg> Add
                    </button>
                    <div class="add-submenu">
                        <div class="add-submenu-item" onclick="openEditor(null)">
                            <svg class="icon-svg" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/></svg>
                            Add New Row
                        </div>
                        <div class="add-submenu-item" onclick="openAddFyModal()">
                            <svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7zM16 3v4M8 3v4M4 11h16"/></svg>
                            Add New FY
                        </div>
                        <div class="add-submenu-item super-only" onclick="openPresetValuesModal()">
                            <svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
                            Manage Preset Values
                        </div>
                        <div class="add-submenu-item super-only" onclick="openLinkedRulesModal()">
                            <svg class="icon-svg" viewBox="0 0 24 24"><path d="M5 9l4 4l4-4M5 15l4-4l4 4M17 4v16"/></svg>
                            Manage Linked Rules
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bulk delete bar -->
    <div class="bulk-bar" id="bulk-bar">
        <span id="bulk-count">0 selected</span>
        <button class="btn btn-danger btn-sm del-only" onclick="bulkDelete()">Delete Selected</button>
        <button class="btn btn-outline btn-sm" onclick="clearSelection()">Clear</button>
    </div>

    <!-- Search + pagination controls -->
    <div class="table-controls">
        <input class="search-box" type="text" id="search-box" placeholder="Search by serial, manufacturer, technician..." oninput="debounceSearch()">
        <select class="per-page-select" id="per-page-select" onchange="changePerPage(this.value)">
            <option value="10">10 per page</option>
            <option value="50" selected>50 per page</option>
            <option value="100">100 per page</option>
        </select>
        <span id="total-label" style="font-size:13px;color:var(--muted);"></span>
    </div>

    <div class="card table-container">
        <table id="burn-in-table">
            <thead><tr id="burn-in-head"></tr></thead>
            <tbody id="burn-in-body"></tbody>
        </table>
    </div>
    <div class="pagination" id="pagination"></div>
</div>

<!-- ════════════════════════════════════
     MODALS
════════════════════════════════════ -->

<!-- Login -->
<div class="modal-overlay" id="login-modal">
    <div class="modal">
        <h3>Portal Login</h3>
        <div class="input-group" style="margin-top:15px;"><label>Username</label><input type="text" id="login-user" autocomplete="off" oninput="this.value=this.value.toLowerCase()"></div>
        <div class="input-group"><label>Password</label><input type="password" id="login-pass" autocomplete="new-password"></div>
        <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:20px;">
            <button class="btn btn-outline" onclick="closeModals()">Cancel</button>
            <button class="btn btn-coral" onclick="login()">Login</button>
        </div>
    </div>
</div>

<!-- Force Reset -->
<div class="modal-overlay" id="force-reset-modal">
    <div class="modal">
        <h3 style="color:#dc2626;">Password Reset Required</h3>
        <p class="hint" style="margin-bottom:15px;">Your temporary password has expired. Set a permanent password now.</p>
        <div class="input-group"><label>New Password</label><input type="password" id="reset-new-pass" autocomplete="new-password"><p class="hint">Min 8 chars, 1 number, 1 special character.</p></div>
        <div style="text-align:right;"><button class="btn btn-coral" onclick="submitForcedReset()">Update & Login</button></div>
    </div>
</div>

<!-- My Profile -->
<div class="modal-overlay" id="my-profile-modal">
    <div class="modal">
        <h3>My Profile</h3>
        <div style="display:flex;gap:15px;margin:15px 0;">
            <div class="avatar-circle" style="width:64px;height:64px;font-size:24px;" id="profile-avatar-preview">U</div>
            <div class="input-group" style="flex:1;"><label>Profile Picture (Optional)</label><input type="file" accept="image/*" onchange="encodeImageFileAsURL(this)"></div>
        </div>
        <div style="display:flex;gap:10px;">
            <div class="input-group" style="flex:1;"><label>First Name</label><input type="text" id="p-first"></div>
            <div class="input-group" style="flex:1;"><label>Last Name</label><input type="text" id="p-last"></div>
        </div>
        <div class="input-group"><label>Email</label><input type="email" id="p-email"></div>
        <div class="input-group"><label>Phone</label><input type="text" id="p-phone"></div>
        <div class="input-group"><label>Update Password (Optional)</label><input type="password" id="p-pass" autocomplete="new-password"></div>
        <div style="text-align:right;">
            <button class="btn btn-outline" onclick="closeModals()">Cancel</button>
            <button class="btn btn-coral" onclick="saveProfile()">Save Profile</button>
        </div>
    </div>
</div>

<!-- Create/Edit User -->
<div class="modal-overlay" id="add-user-modal">
    <div class="modal">
