        if (allVals.length) {
            // Show dropdown of existing preset values + option to type a new one
            const opts = allVals.map(v => `<option value="${v}">${v}</option>`).join('');
            cell.innerHTML = `
                <div style="flex:2;display:flex;flex-direction:column;gap:4px;">
                    <select id="rb-act-val-${idx}" style="width:100%;padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-size:13px;">
