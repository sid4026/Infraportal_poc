<!-- ════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════ -->
<script>
    const API = "http://" + window.location.host;
    let BURN_IN_DATA = [];
    let SYSTEM_LOOKUPS = {};
    let OS_BUILDS = [];
    let MY_PROFILE = {};
    let USER_LIST_CACHE = [];
    let FY_LIST = [];
    let CURRENT_FY = 'FY-2627';
    let IDLE_TIMER;
    let SEARCH_TIMER;
    let CURRENT_PAGE = 1;
    let CURRENT_PER_PAGE = 50;
    let TOTAL_ROWS = 0;
    let PENDING_CONFLICTS = [];
    let SELECTED_IDS = new Set();

    const COLUMNS = ["Report ID","Date Performed","Technician","Manufacturer","Model Number","Serial Number","CPU Tier","CPU Generation","CPU Architecture","RAM Brand","RAM Size (GB)","RAM Freq (MHz)","RAM Type","RAM Config","Storage Brand","Storage Size","Storage Type","GPU Type","GPU Model","OS Version","OS Release","OS Build ID","CPU Test","RAM Test","Storage Test","Video Test","2D Graphics","3D Graphics","Test Combination","CPU Load %","RAM Load %","Storage Load %","GPU Load %","CPU Max °C","RAM Max °C","SSD Max °C","GPU Max °C","Duration (hrs)","Result","Is Retest","Retest Attempt","Retest Reason","Notes"];
    const FORMULA_COLS = new Set(["Report ID","OS Build ID","Test Combination","CPU Load %","RAM Load %","Storage Load %","GPU Load %","CPU Max °C","RAM Max °C","SSD Max °C","GPU Max °C"]);

    // Phase 2 — BASE_ARRAYS removed. All dropdown values come from DB via preset_values table.
    let CURRENT_TEMPLATE_ID = null;  // resolved at init from /api/projects
    let LINKED_RULES = [];           // fetched from /api/template/<id>/linked_rules
    let DISPLAY_RULES = [];          // fetched from /api/template/<id>/display_rules

    const SVG_FLOPPY = `<svg class="icon-svg" viewBox="0 0 24 24"><path d="M6 4h10l4 4v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><path d="M16 4v6H8V4"/><path d="M8 14h8v6H8z"/></svg>`;
    const SVG_CANCEL = `<svg class="icon-svg" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>`;
    const SVG_PENCIL = `<svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4z"/><path d="M13.5 6.5l4 4"/></svg>`;
    const SVG_TRASH  = `<svg class="icon-svg" viewBox="0 0 24 24"><path d="M4 7h16M10 11v6M14 11v6M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-12M9 7V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3"/></svg>`;
    const SVG_POWER  = `<svg class="icon-svg" viewBox="0 0 24 24"><path d="M7 6a7.75 7.75 0 1 0 10 0M12 4v8"/></svg>`;

    // ── INIT ──────────────────────────────────────
    async function init() {
        // Resolve BIT template_id first — dropdowns and rules depend on it
        try {
            const projRes = await fetch(API + "/api/projects");
            const projects = await projRes.json();
            const bit = projects.find(p => p.project_name === 'BIT');
            CURRENT_TEMPLATE_ID = bit ? bit.template_id : null;
        } catch(e) { CURRENT_TEMPLATE_ID = null; }

        await Promise.all([
            fetchLookups(),
            fetchOsBuilds(),
            fetchFiscalYears(),
            fetchLinkedRules(),
            fetchDisplayRules()
        ]);

        // Build table header with checkbox
        document.getElementById('burn-in-head').innerHTML =
            '<th class="cb-col del-only"><input type="checkbox" id="select-all-cb" onchange="toggleSelectAll(this.checked)"></th>' +
            COLUMNS.map(c => `<th>${c}</th>`).join('') +
            '<th class="admin-only" style="min-width:80px;text-align:center;">Actions</th>';

        document.onmousemove = resetIdle;
        document.onkeypress = resetIdle;

        const token = localStorage.getItem("token");
        if (token) {
            try {
                const res = await fetch(API + "/api/auth/me", { headers: { "X-Auth-Token": token } });
                const data = await res.json();
                if (data.ok) { applyAuth(data); } else { logout(); }
            } catch(e) { logout(); }
        }
        nav('home');
    }

    // ── LOOKUPS ───────────────────────────────────
    async function fetchLookups() {
        // Phase 2: SYSTEM_LOOKUPS is built from two sources:
        //   1. preset_values table (template-scoped dropdown values)
        //   2. lookups table (Technician only — managed separately)
        SYSTEM_LOOKUPS = {};

        // Technicians from lookups table
        try {
            const res = await fetch(API + "/api/lookups");
            const rows = await res.json();
            SYSTEM_LOOKUPS['Technician'] = rows.filter(r => r.category === 'Technician');
        } catch(e) { SYSTEM_LOOKUPS['Technician'] = []; }

        // Preset values from template
        if (CURRENT_TEMPLATE_ID) {
            try {
                const res = await fetch(API + `/api/template/${CURRENT_TEMPLATE_ID}/preset_values`);
                const pvRows = await res.json();
                pvRows.forEach(pv => {
                    if (!SYSTEM_LOOKUPS[pv.column_name]) SYSTEM_LOOKUPS[pv.column_name] = [];
                    SYSTEM_LOOKUPS[pv.column_name].push({ id: pv.id, lookup_key: pv.value });
                });
            } catch(e) { /* no preset values yet — dropdowns will be empty until SuperAdmin adds them */ }
        }
    }

    async function fetchOsBuilds() {
        const res = await fetch(API + "/api/os_builds");
        OS_BUILDS = await res.json();
        const names = [...new Set(OS_BUILDS.map(o => o.os_name))];
        SYSTEM_LOOKUPS['OS Version'] = names.map(n => ({ lookup_key: n }));
    }

    function getOsReleases(osName) {
        return OS_BUILDS.filter(o => o.os_name === osName).map(o => o.os_release);
    }

    // ── PHASE 2: LINKED RULES ENGINE ─────────────
    async function fetchLinkedRules() {
        if (!CURRENT_TEMPLATE_ID) { LINKED_RULES = []; return; }
        try {
            const res = await fetch(API + `/api/template/${CURRENT_TEMPLATE_ID}/linked_rules`);
            LINKED_RULES = await res.json();
        } catch(e) { LINKED_RULES = []; }
    }

    // Called from inline editor on any field change.
    // Evaluates LINKED_RULES and auto-fills matched THEN columns (first-match wins per column).
    function evaluateRules() {
        if (!LINKED_RULES.length) return;
        const snapshot = {};
        COLUMNS.forEach(c => {
            const el = document.getElementById(`i-${c}`);
            if (el) snapshot[c] = el.value;
        });
        const applied = {};
        for (const rule of LINKED_RULES) {
            if (applied[rule.then_column]) continue; // first-match wins
            const fieldVal = (snapshot[rule.if_column] || '').trim();
            const condVal  = (rule.if_value || '').trim();
            const op = rule.operator || 'equals';
            let match = false;
            if (op === 'equals')     match = fieldVal.toLowerCase() === condVal.toLowerCase();
            if (op === 'not_equals') match = fieldVal.toLowerCase() !== condVal.toLowerCase();
            if (op === 'contains')   match = fieldVal.toLowerCase().includes(condVal.toLowerCase());
            if (match) {
                const el = document.getElementById(`i-${rule.then_column}`);
                if (!el) continue;
                if (el.tagName === 'SELECT') {
                    const exists = Array.from(el.options).some(o => o.value === rule.then_value);
                    if (exists) { el.value = rule.then_value; applied[rule.then_column] = true; }
                } else {
                    el.value = rule.then_value;
                    applied[rule.then_column] = true;
                }
            }
        }
    }

    // ── PHASE 2: DISPLAY RULES ENGINE ────────────
    async function fetchDisplayRules() {
        if (!CURRENT_TEMPLATE_ID) { DISPLAY_RULES = []; return; }
        try {
            const res = await fetch(API + `/api/template/${CURRENT_TEMPLATE_ID}/display_rules`);
            DISPLAY_RULES = await res.json();
        } catch(e) { DISPLAY_RULES = []; }
    }

    // Returns CSS class string for a cell based on DISPLAY_RULES. Empty string = no match.
    function getCellClass(colName, cellValue) {
        for (const rule of DISPLAY_RULES) {
            if (rule.column_name !== colName) continue;
            const val  = String(cellValue === null || cellValue === undefined ? '' : cellValue);
            const rval = String(rule.condition_value || '');
            let match = false;
            if (rule.operator === 'equals')     match = val === rval;
            if (rule.operator === 'not_equals') match = val !== rval;
            if (rule.operator === 'contains')   match = val.includes(rval);
            if (rule.operator === 'gte')        match = parseFloat(val) >= parseFloat(rval);
            if (rule.operator === 'lte')        match = parseFloat(val) <= parseFloat(rval);
            if (match) {
                const colorClass = rule.highlight_color ? `highlight-${rule.highlight_color}` : '';
                const fontClass  = rule.font_style && rule.font_style !== 'normal' ? `font-${rule.font_style}` : '';
                return [colorClass, fontClass].filter(Boolean).join(' ');
            }
        }
        return '';
    }

    function getOsBuildId(osName, osRelease) {
        const match = OS_BUILDS.find(o => o.os_name === osName && o.os_release === osRelease);
        return match ? match.build_id : 'Manual Entry';
    }

    // ── FISCAL YEARS ──────────────────────────────
    async function fetchFiscalYears() {
        const res = await fetch(API + "/api/fiscal_years");
        FY_LIST = await res.json();
        if (FY_LIST.length > 0 && !FY_LIST.find(f => f.fy_key === CURRENT_FY)) {
            CURRENT_FY = FY_LIST[0].fy_key;
        }
        renderFyTabs();
        updateFyTitle();
    }

    function renderFyTabs() {
        document.getElementById('fy-tabs').innerHTML = FY_LIST.map(f =>
            `<div class="fy-tab ${f.fy_key === CURRENT_FY ? 'active' : ''}" onclick="switchFy('${f.fy_key}')">${f.fy_label}</div>`
        ).join('');
    }

    function updateFyTitle() {
        const fy = FY_LIST.find(f => f.fy_key === CURRENT_FY);
        document.getElementById('fy-title-text').textContent = `Client Machine Analytics — ${fy ? fy.fy_label : CURRENT_FY}`;
    }

    function switchFy(fyKey) {
        CURRENT_FY = fyKey;
        CURRENT_PAGE = 1;
        renderFyTabs();
        updateFyTitle();
        loadBurnInData();
    }

    function openAddFyModal() { openModal('add-fy-modal'); }
    function openFyRenameModal() {
        const fy = FY_LIST.find(f => f.fy_key === CURRENT_FY);
        document.getElementById('rename-fy-label').value = fy ? fy.fy_label : '';
        openModal('rename-fy-modal');
    }

    async function saveFy() {
        const key = document.getElementById('new-fy-key').value.trim();
        const label = document.getElementById('new-fy-label').value.trim() || key;
        if (!key) { alert('FY Key is required.'); return; }
        const res = await fetch(API + "/api/superadmin/fiscal_years", {
            method: "POST", headers: { "Content-Type": "application/json", "X-Auth-Token": localStorage.getItem("token") },
            body: JSON.stringify({ fy_key: key, fy_label: label })
        });
        const data = await res.json();
        if (data.error) { alert(data.error); return; }
        closeModals();
        await fetchFiscalYears();
        switchFy(key);
    }

    async function saveFyRename() {
        const label = document.getElementById('rename-fy-label').value.trim();
        if (!label) { alert('Label cannot be empty.'); return; }
        await fetch(API + `/api/superadmin/fiscal_years/${CURRENT_FY}`, {
            method: "PUT", headers: { "Content-Type": "application/json", "X-Auth-Token": localStorage.getItem("token") },
            body: JSON.stringify({ fy_label: label })
        });
        closeModals();
        await fetchFiscalYears();
        updateFyTitle();
    }

    // ── NAV ───────────────────────────────────────
    function nav(pageId) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById('page-' + pageId).classList.add('active');
        document.querySelectorAll('.nav-tgt').forEach(n => n.classList.remove('active'));
        const map = { home:'nav-home', burnin:'nav-services', achievements:'nav-achievements', about:'nav-about', contact:'nav-contact', users:'nav-admin', logs:'nav-admin', 'os-builds':'nav-admin' };
        if (map[pageId]) document.getElementById(map[pageId])?.classList.add('active');
        if (pageId === 'burnin') loadBurnInData();
        if (pageId === 'vault') loadVault();
        if (pageId === 'users') loadUsers();
        if (pageId === 'logs') loadLogs();
