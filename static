    function openModal(id) {
        document.querySelectorAll(`#${id} input`).forEach(i => { if (i.type !== 'file' && i.type !== 'checkbox') i.value = ''; });
        document.getElementById(id).classList.add('active');
    }
    function closeModals() { document.querySelectorAll('.modal-overlay').forEach(m => m.classList.remove('active')); }

    // ── AUTH ──────────────────────────────────────
    async function login() {
        const user = document.getElementById('login-user').value;
        const res = await fetch(API + "/api/auth/login", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ username: user, password: document.getElementById('login-pass').value })
        });
        const data = await res.json();
        if (data.requires_reset) {
            closeModals();
            document.getElementById('force-reset-modal').setAttribute('data-user', data.username);
            openModal('force-reset-modal');
        } else if (data.ok) {
            localStorage.setItem("token", data.token);
            data.username = data.username || user;
            applyAuth(data);
            closeModals();
            nav('burnin');
        } else { alert(data.error || "Login failed."); }
    }

    async function submitForcedReset() {
        const user = document.getElementById('force-reset-modal').getAttribute('data-user');
        const pass = document.getElementById('reset-new-pass').value;
        if (!/^(?=.*[0-9])(?=.*[!@#$%^&*])[a-zA-Z0-9!@#$%^&*]{8,}$/.test(pass)) {
            alert("Min 8 chars, 1 number, 1 special char."); return;
        }
        const res = await fetch(API + "/api/auth/force_reset", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ username: user, new_password: pass })
        });
        if ((await res.json()).ok) { closeModals(); openModal('login-modal'); }
    }

    function applyAuth(data) {
        MY_PROFILE = data;
        document.body.className = `is-auth is-${data.role} ${data.can_delete ? 'can-delete' : ''}`;
        document.getElementById('nav-username').innerText = data.username;
        document.getElementById('nav-avatar').innerHTML = data.avatar
            ? `<img src="${data.avatar}">` : data.username.charAt(0).toUpperCase();
        resetIdle();
        // Fetch rules now that we have a valid token (rules need auth)
        fetchRules();
    }

    function logout() { localStorage.clear(); document.body.className = ''; clearTimeout(IDLE_TIMER); nav('home'); }
    function resetIdle() {
        clearTimeout(IDLE_TIMER);
        if (document.body.classList.contains('is-auth')) {
            IDLE_TIMER = setTimeout(() => { alert("Session expired."); logout(); }, 30 * 60 * 1000);
        }
    }

