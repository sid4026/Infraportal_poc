            setTimeout(() => {
                const sel = document.getElementById(`rb-act-val-${idx}`);
                if (sel) sel.addEventListener('change', () => {
                    const wrap = document.getElementById(`rb-act-custom-wrap-${idx}`);
                    if (wrap) wrap.style.display = sel.value === '__custom__' ? 'flex' : 'none';
                });
            }, 0);
        } else {
            // No preset values for this column — plain text + shortcut to add one
            cell.innerHTML = `
